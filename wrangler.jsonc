{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "miaow-lol",
  "main": "./worker/index.js",
  "compatibility_date": "2026-03-14",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/", "/index.html", "/robots.txt", "/sitemap.xml"]
  }
}
